# Zoho Desk OAuth credentials for the kb-local Zoho MCP server.
# Copy to .env (which is gitignored) and fill in real values.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Optional: bearer auth for the MCP transport. JSON map of token -> claims.
# Leave unset for local/fleet stdio use.
# AUTH_TOKEN={"sometoken": {"sub": "fleet", "scopes": ["read:data"]}}
