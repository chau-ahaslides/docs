# Zoho Desk OAuth credentials for the kb-local Zoho MCP server.
# These may also live in the kb repo-root .env (both are loaded; local wins).
#
# ZOHO_REFRESH_TOKEN is long-lived but must be minted once from a short-lived
# self-client grant code -- see README / bootstrap_token.py.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Optional. Only needed for the client_credentials grant (no refresh token) or
# if Zoho returns missing_org_info. Find it in Desk -> Setup -> Developer Space.
# ZOHO_ORG_ID=

# Optional. Override for non-US datacenters (.eu / .in / .com.au / .jp).
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
# ZOHO_API_BASE=https://desk.zoho.com
# ZOHO_SCOPE=Desk.tickets.READ

# Optional. Point at an alternate .env (used by the fleet-folder MCP launch).
# ZOHO_ENV_FILE=

# Optional. Set ZOHO_MASK=0 to disable customer-identity masking (debugging).
# Optional bearer auth for the MCP transport. JSON map of token -> claims.
# AUTH_TOKEN={"sometoken": {"sub": "fleet", "scopes": ["read:data"]}}
