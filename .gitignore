
# Agent-Fleet local files (secrets + sidecars stay ignored; shared config is committed)
.agent-fleet/*
!.agent-fleet/config.json
!.agent-fleet/config.example.json
.env
.agent-fleet/*.local

# Tutorial video render outputs — kept local, never committed (published copy lives on YouTube)
out-videos/

# Node workspace for the tutorial-video recording pipeline
node_modules/

# Zoho MCP local secrets / token cache (mcp/zoho/.env is covered by the .env rule above)
mcp/zoho/access_token.txt
__pycache__/
