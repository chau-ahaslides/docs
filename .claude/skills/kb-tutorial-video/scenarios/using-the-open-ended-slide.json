{
  "steps": [
    {
      "id": "oe-welcome",
      "path": "/apps/presentations",
      "title": "Let's build an Open Ended slide!",
      "description": "An Open Ended slide lets your audience answer in their own words — no fixed choices, just real responses. Click Next to begin.",
      "targetSelector": ".new-presentation-button",
      "action": null
    },
    {
      "id": "oe-create",
      "path": "/apps/presentations",
      "title": "Create a new presentation",
      "description": "Click 'New presentation' to start a fresh deck.",
      "targetSelector": ".new-presentation-button",
      "action": {
        "type": "click",
        "selector": ".new-presentation-button"
      }
    },
    {
      "id": "oe-pick-type",
      "path": "/presentation/*",
      "title": "Pick the Open Ended slide type",
      "description": "Select 'Open Ended' from the slide type picker. It captures free-text answers from your audience.",
      "targetSelector": "[aria-label=\"Open Ended\"][data-testid=\"editor-new-slide-type-item-v2-button\"]",
      "pauseMs": 1500,
      "action": {
        "type": "click",
        "selector": "[aria-label=\"Open Ended\"][data-testid=\"editor-new-slide-type-item-v2-button\"]"
      }
    },
    {
      "id": "oe-type-question",
      "path": "/presentation/*",
      "title": "Write your question",
      "description": "Type your question here. Make it specific to spark a real response.",
      "targetSelector": "[aria-label=\"Question text\"]",
      "pauseMs": 1000,
      "action": {
        "type": "input-match",
        "selector": "[aria-label=\"Question text\"]",
        "value": "What's one thing you'd change about our team meetings?"
      }
    },
    {
      "id": "oe-layout",
      "path": "/presentation/*",
      "title": "Choose how responses display",
      "description": "Grid shows all responses at once; One by one reveals them individually. Click to switch layouts.",
      "targetSelector": ".bars-box-content.layout",
      "pauseMs": 500,
      "action": {
        "type": "click",
        "selector": ".bars-box-content.layout"
      },
      "mainInteractions": [
        {
          "selector": ".bars-box-content.layout",
          "label": "click layout again to cycle",
          "pauseAfterMs": 1000
        }
      ]
    },
    {
      "id": "oe-preview-open",
      "path": "/presentation/*",
      "title": "Hit Preview to rehearse your slide",
      "description": "Preview opens a split view — Presenter screen on the left, Participant screen on the right. Use it to test your slide before going live.",
      "targetSelector": ".iframe-wrapper-audience",
      "pauseMs": 1000,
      "action": null,
      "mainInteractions": [
        {
          "type": "jsEval",
          "js": "document.querySelector('[data-testid=\"editor-side-right-nav-settings-button\"]')?.click()",
          "label": "open Settings modal",
          "pauseAfterMs": 2500
        },
        {
          "selector": "[data-testid=\"presentation-settings-tab-presentation-language-button\"]",
          "label": "click Presentation Language tab",
          "pauseAfterMs": 1500
        },
        {
          "type": "select",
          "selector": "[data-testid=\"presentation-settings-language-select\"]",
          "value": "en",
          "label": "set audience language to English",
          "pauseAfterMs": 1500
        },
        {
          "selector": ".aha-modal__close-button",
          "label": "close Settings modal",
          "pauseAfterMs": 1000
        },
        {
          "selector": "[data-testid=\"editor-middle-preview-button\"]",
          "label": "open preview",
          "pauseAfterMs": 5000
        }
      ]
    },
    {
      "id": "oe-preview-audience",
      "path": "/presentation/*",
      "title": "Audience types their answer here",
      "description": "Participants type their answer and hit Submit. Responses arrive instantly on your screen.",
      "targetSelector": ".iframe-wrapper-audience",
      "pauseMs": 1000,
      "action": null,
      "previewInteractions": [
        {
          "frameMatch": "audience.",
          "selector": "[data-testid=\"audience-open-ended-textarea\"]",
          "type": "type",
          "value": "Shorter weekly stand-ups",
          "label": "type open-ended answer",
          "pauseAfterMs": 1000
        },
        {
          "frameMatch": "audience.",
          "selector": "[data-testid=\"audience-open-ended-submit-button\"]",
          "label": "submit answer",
          "pauseAfterMs": 2000
        }
      ]
    },
    {
      "id": "oe-preview-results",
      "path": "/presentation/*",
      "title": "Responses appear live",
      "description": "Each answer pops up instantly. Hit Present to go live.",
      "targetSelector": ".iframe-wrapper-presenter",
      "pauseMs": 1000,
      "action": null
    }
  ]
}
